# Copy this file to `.env` in the same directory and fill in real values.
# `.env` MUST live at ~/.cursor/skills/shopify-asset-sync/.env — outside any
# regional Shopify repo's worktree, so there's no accidental-commit path.
#
# Credentials come from the Shopify Dev Dashboard, NOT from the store admin:
#   1. Create an app at https://dev.shopify.com/dashboard/  (one per store org)
#   2. Install the app on the target store (Dev stores tab → Install)
#   3. Open the app → Settings → copy "Client ID" and "Client secret"
#   4. The app and the store MUST be in the same Dev Dashboard organisation,
#      otherwise OAuth returns `shop_not_permitted`.
#
# Role convention:
#   SRC = source store  →  the one we READ from (needs `read_files`)
#   DST = destination   →  the one we WRITE to  (needs `read_files`, `write_files`)
#
# Store format: either `kenisph` or `kenisph.myshopify.com` (the tool
# normalises both). Do NOT include `https://` or paths.

# ─── SRC source store (e.g. kenistech / NA) ─────────────────────────────
# Required Admin API scope: read_files
SHOPIFY_SRC_STORE=kenistech.myshopify.com
SHOPIFY_SRC_CLIENT_ID=your-src-client-id
SHOPIFY_SRC_CLIENT_SECRET=your-src-client-secret

# ─── DST destination store (e.g. kenisph / PH) ──────────────────────────
# Required Admin API scopes: read_files, write_files
SHOPIFY_DST_STORE=kenisph.myshopify.com
SHOPIFY_DST_CLIENT_ID=your-dst-client-id
SHOPIFY_DST_CLIENT_SECRET=your-dst-client-secret
